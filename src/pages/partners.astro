---
import Base from '../layouts/Base.astro';
import WaferMark from '../components/WaferMark.astro';
import { QUOTES } from '../data/stats';
import { LINKS } from '../lib/feeds';
const year = new Date().getFullYear();

const PERKS = [
  'Host-read spots in the episode',
  'Logo on video and clips',
  'Daily newsletter placement',
  'Category exclusivity',
  'Custom episode opportunities',
];

// Real catalog episodes with industry leaders — the caliber of content
// a partner's brand sits beside.
const EXAMPLES = [
  {
    company: 'THE DEEP DIVE',
    title: 'A Masterclass on Lithography',
    videoId: 'WWbEfDilXuM',
  },
  {
    company: 'NEWS & ANALYSIS',
    title: "Qualcomm's HBC Memory, Alphawave, Modular, and More",
    videoId: 'gbxIFOtYPrE',
  },
  {
    company: 'WITH META',
    title: 'Meta VP Matt Steiner on Ads Infra, GPUs, MTIA, and LLM-Written Kernels',
    videoId: '5dWovJ4YHTY',
  },
];
---
<Base
  title="Partner with Semi Doped"
  description="Reach the engineers who design the silicon and the investors who fund it. Weekly podcast + daily newsletter on the business and technology of semiconductors."
  noindex={true}
>
  <header class="phero">
    <div class="wafer-bg"><WaferMark size={420} /></div>
    <div class="wrap inner">
      <a class="home-link" href="/">
        <WaferMark size={30} />
        <span class="wm"><span class="s">SEMI </span><span class="d">DOPED</span></span>
      </a>
      <div class="kicker">PARTNERSHIPS</div>
      <h1>Your brand, beside analysis this audience already trusts.</h1>
      <p class="dek">Austin Lyons and Vik Sekar cover the chips, the supply chain, and the companies powering the AI buildout, in a weekly ~45-minute podcast and a daily newsletter. Deep enough for the engineers who design the silicon, clear enough for the investors who fund it.</p>
    </div>
  </header>

  <section class="motto">
    <div class="wrap motto-inner">
      <WaferMark size={44} />
      <p class="motto-line">The world&rsquo;s most interesting industry <span class="dot">&middot;</span><br class="brk" /> and its most interesting people.</p>
    </div>
  </section>

  <section class="who">
    <div class="wrap">
      <div class="kicker">WHO'S LISTENING</div>
      <p class="big">Listeners at <b>every major chipmaker</b>, the <b>leading AI labs</b>, and <b>60+ investment firms</b>, on their corporate email.</p>
      <p class="muted">Engineers, executives, and investors across 110 countries. Top cities: New York, Singapore, San Francisco, Taipei, London, Bangalore.</p>
      <div class="quotes">
        {QUOTES.map((q) => (
          <blockquote>
            <span class="qmark" aria-hidden="true">&ldquo;</span>
            <p>{q.text}&rdquo;</p>
            <cite>{q.who}</cite>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <section class="examples">
    <div class="wrap">
      <div class="kicker">THE COMPANY YOU'LL KEEP</div>
      <p class="ex-lead">Your brand sits beside episodes like these.</p>
      <div class="exgrid">
        {EXAMPLES.map((ex) => (
          <a class="excard" href={`https://www.youtube.com/watch?v=${ex.videoId}`} rel="noopener">
            <span class="ex-thumb">
              <img src={`https://i.ytimg.com/vi/${ex.videoId}/hqdefault.jpg`} alt={ex.title} loading="lazy" width="480" height="360" />
              <span class="ex-play" aria-hidden="true"></span>
            </span>
            <span class="ex-body">
              <span class="ex-co">{ex.company}</span>
              <span class="ex-title">{ex.title}</span>
              <span class="ex-go">Watch →</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="offer">
    <div class="wrap">
      <div class="kicker">WHAT PARTNERS GET</div>
      <p class="approach">Partnerships are formed directly with us, the hosts. Spots are host-read and written with you, embedded in the episode, and carried across the show, YouTube, and the Daily.</p>
      <ol class="perks">
        {PERKS.map((perk, i) => (
          <li>
            <span class="idx">{String(i + 1).padStart(2, '0')}</span>
            <span class="perk">{perk}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="ask">
    <div class="wafer-bg ask-wafer"><WaferMark size={220} /></div>
    <div class="wrap ask-inner">
      <h2>The founding partner roster is intentionally small.</h2>
      <p>Founding partners lock in today&rsquo;s rates. Email us for availability and the full kit.</p>
      <a class="btn btn-solid" href="mailto:sponsor@semidoped.com?subject=Semi%20Doped%20partnership">Request the partnership kit</a>
      <div class="contacts">
        <span><a href="mailto:sponsor@semidoped.com">SPONSOR@SEMIDOPED.COM</a></span>
        <span>OR DM · <a href="https://x.com/semidoped" rel="noopener">@SEMIDOPED</a> / <a href="https://x.com/austinsemis" rel="noopener">@AUSTINSEMIS</a> / <a href="https://x.com/vikramskr" rel="noopener">@VIKRAMSKR</a></span>
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap foot">
      <span class="mono-meta links">
        <a href="/">HOME</a> /
        <a href={LINKS.podcast}>PODCAST</a> /
        <a href={LINKS.daily}>DAILY</a> /
        <a href={LINKS.youtube} rel="noopener">YOUTUBE</a>
      </span>
      <span class="mono-meta">© {year} SEMI DOPED LLC</span>
    </div>
  </footer>
</Base>

<style>
  /* Hero: dark, warm glow, oversized wafer as the visual anchor */
  .phero {
    background: var(--black);
    color: var(--on-black);
    position: relative;
    overflow: hidden;
  }
  .phero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(55% 120% at 78% 30%, rgba(233, 104, 34, 0.24), transparent 62%);
    pointer-events: none;
  }
  .phero .wafer-bg {
    position: absolute;
    right: -60px;
    top: 50%;
    transform: translateY(-46%);
    opacity: 0.85;
    pointer-events: none;
  }
  @media (max-width: 900px) {
    .phero .wafer-bg { opacity: 0.18; right: -140px; }
  }
  .phero .inner {
    position: relative;
    padding-top: var(--sp-xl);
    padding-bottom: var(--sp-3xl);
    display: flex;
    flex-direction: column;
    gap: var(--sp-lg);
    align-items: flex-start;
  }
  .home-link { display: flex; align-items: center; gap: 10px; text-decoration: none; margin-bottom: var(--sp-xl); }
  .home-link .wm { font-family: var(--font-display); font-weight: 700; font-size: 16px; letter-spacing: 0.12em; }
  .home-link .s { color: #fff; }
  .home-link .d { color: var(--accent); }
  .phero .kicker { color: var(--accent); }
  h1 {
    font-size: clamp(30px, 4.6vw, 48px);
    max-width: 20ch;
    color: #fff;
  }
  .dek { font-size: 18px; color: var(--on-black-muted); max-width: 56ch; }

  section { border-bottom: 1px solid var(--hairline); }
  section .wrap { padding-top: var(--sp-2xl); padding-bottom: var(--sp-2xl); }
  section .kicker { margin-bottom: var(--sp-lg); }

  /* Motto band */
  .motto-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-md);
  }
  .motto-line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(22px, 3.2vw, 32px);
    line-height: 1.35;
    letter-spacing: 0.01em;
    text-align: center;
  }
  .motto-line .dot { color: var(--accent); }
  @media (min-width: 700px) { .brk { display: none; } }

  /* Who's listening */
  .big {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(21px, 2.8vw, 28px);
    line-height: 1.4;
    max-width: 38ch;
    margin-bottom: var(--sp-md);
  }
  .big b { color: var(--accent); font-weight: 600; }
  .muted { color: var(--muted); max-width: 62ch; }
  .quotes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-md);
    margin-top: var(--sp-xl);
  }
  @media (max-width: 820px) { .quotes { grid-template-columns: 1fr; } }
  blockquote {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: var(--sp-xl) var(--sp-lg) var(--sp-lg);
  }
  .qmark {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 44px;
    line-height: 0.6;
    color: var(--accent);
    margin-bottom: var(--sp-sm);
  }
  blockquote p { font-size: 16px; line-height: 1.55; }
  blockquote cite {
    display: block;
    margin-top: var(--sp-md);
    padding-top: var(--sp-md);
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Example episodes */
  .ex-lead {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(20px, 2.6vw, 26px);
    margin-bottom: var(--sp-xl);
  }
  .exgrid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-md);
  }
  @media (max-width: 820px) { .exgrid { grid-template-columns: 1fr; } }
  .excard {
    display: flex;
    flex-direction: column;
    background: #070707;
    border-radius: var(--radius-md);
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.2s ease;
  }
  .excard:hover { transform: translateY(-2px); }
  .ex-thumb { position: relative; display: block; aspect-ratio: 16 / 9; overflow: hidden; }
  .ex-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ex-play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.94;
  }
  .ex-play::after {
    content: '';
    position: absolute;
    left: 55%;
    top: 50%;
    transform: translate(-50%, -50%);
    border-left: 15px solid #fff;
    border-top: 9px solid transparent;
    border-bottom: 9px solid transparent;
  }
  .ex-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
    padding: var(--sp-lg);
    flex: 1;
  }
  .ex-co {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--accent);
  }
  .ex-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    line-height: 1.4;
    color: #fff;
  }
  .ex-go {
    margin-top: auto;
    padding-top: var(--sp-md);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13.5px;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  /* Approach line */
  .approach {
    font-size: 17px;
    color: var(--muted);
    max-width: 62ch;
    margin-bottom: var(--sp-lg);
  }

  /* Perks: ruled rows with mono indexes */
  .perks {
    list-style: none;
    max-width: 720px;
    border-top: 1px solid var(--hairline);
  }
  .perks li {
    display: flex;
    align-items: baseline;
    gap: var(--sp-lg);
    padding: 14px 4px;
    border-bottom: 1px solid var(--hairline);
  }
  .perks .idx {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.06em;
    flex: none;
  }
  .perks .perk {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17.5px;
    letter-spacing: 0.015em;
  }

  /* Closing ask: dark band mirroring the hero */
  .ask {
    background: var(--black);
    color: var(--on-black);
    position: relative;
    overflow: hidden;
    border-bottom: none;
  }
  .ask::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(50% 120% at 22% 60%, rgba(233, 104, 34, 0.2), transparent 62%);
    pointer-events: none;
  }
  .ask-wafer {
    position: absolute;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.9;
    pointer-events: none;
  }
  @media (max-width: 900px) { .ask-wafer { opacity: 0.15; } }
  .ask-inner {
    position: relative;
    padding-top: var(--sp-3xl);
    padding-bottom: var(--sp-3xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-md);
  }
  .ask h2 {
    color: #fff;
    font-size: clamp(24px, 3.4vw, 34px);
    max-width: 22ch;
  }
  .ask p { color: var(--on-black-muted); max-width: 50ch; margin-bottom: var(--sp-sm); }
  .contacts {
    display: flex;
    gap: var(--sp-xl);
    flex-wrap: wrap;
    margin-top: var(--sp-lg);
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    color: var(--on-black-muted);
  }
  .contacts a { color: var(--on-black); text-decoration: none; }
  .contacts a:hover { color: var(--accent); }

  footer { border: none; }
  .foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-md);
    padding-top: var(--sp-lg);
    padding-bottom: var(--sp-lg);
  }
  .links a { color: var(--ink); text-decoration: none; transition: color 0.2s ease; }
  .links a:hover { color: var(--accent); }
</style>
