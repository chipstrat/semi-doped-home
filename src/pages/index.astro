---
import Base from '../layouts/Base.astro';
import WaferMark from '../components/WaferMark.astro';
import { getLatestEpisodes, getLatestDaily, formatDate, formatDuration, LINKS } from '../lib/feeds';
import { QUOTES } from '../data/stats';

const [episodes, daily] = await Promise.all([getLatestEpisodes(2), getLatestDaily(3)]);
const year = new Date().getFullYear();
---
<Base title="Semi Doped — Semiconductors, Decoded Daily">
  <!-- Brand hero: the black block IS the front door here -->
  <header class="hero">
    <div class="wrap inner">
      <WaferMark size={64} />
      <h1 class="wm"><span class="s">SEMI </span><span class="d">DOPED</span></h1>
      <p class="tagline">The world&rsquo;s most interesting industry <span class="dot">&middot;</span> and its most interesting people.</p>
      <div class="ctas">
        <a class="btn btn-solid" href={LINKS.podcast}>Listen to the Podcast</a>
        <a class="btn hero-outline" href={LINKS.daily}>Read the Daily</a>
      </div>
      <div class="platforms mono-line">
        <a href={LINKS.youtube} rel="noopener">YOUTUBE</a> /
        <a href={LINKS.apple} rel="noopener">APPLE</a> /
        <a href={LINKS.spotify} rel="noopener">SPOTIFY</a> /
        <a href={LINKS.x} rel="noopener">X</a>
      </div>
    </div>
  </header>

  <!-- Hosts -->
  <section class="hosts">
    <div class="wrap">
      <h2>The engineer&rsquo;s engineer and the chip strategist</h2>
      <div class="hostgrid">
        <div class="host">
          <img class="setphoto" src="/hosts/vik-set.jpg" alt="Vikram Sekar on the Semi Doped set" width="1200" height="650" loading="lazy" />
          <div class="hostmeta">
            <span class="creds">PhD EE</span>
            <a class="affil" href="https://www.viksnewsletter.com/" rel="noopener">Vik&rsquo;s Newsletter →</a>
          </div>
        </div>
        <div class="host">
          <img class="setphoto" src="/hosts/austin-set.jpg" alt="Austin Lyons on the Semi Doped set" width="1200" height="656" loading="lazy" />
          <div class="hostmeta">
            <span class="creds">MSEE + MBA</span>
            <a class="affil" href="https://www.chipstrat.com/" rel="noopener">Chipstrat →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The two properties -->
  <section class="props">
    <div class="wrap propgrid">
      <a class="prop" href={LINKS.podcast}>
        <div class="kicker">THE PODCAST · WEEKLY</div>
        <h2>Semi Doped</h2>
        <div class="latest">
          {episodes.map((ep) => (
            <div class="daily-row">
              <span class="mono-meta">{formatDate(ep.date)} · {formatDuration(ep.duration ?? 0)}</span>
              <span class="item-title">{ep.title}</span>
            </div>
          ))}
        </div>
        <span class="go">semidoped.fm →</span>
      </a>
      <a class="prop" href={LINKS.daily}>
        <div class="kicker">THE NEWSLETTER · EVERY TRADING DAY</div>
        <h2>Semi Doped Daily</h2>
        <p class="desc">The daily brew of semiconductors. The news that matters and what it means, in your inbox every trading day. Free.</p>
        <div class="latest">
          {daily.map((post) => (
            <div class="daily-row">
              <span class="mono-meta">{formatDate(post.date)}</span>
              <span class="item-title sm">{post.title}</span>
            </div>
          ))}
        </div>
        <span class="go">daily.semidoped.com →</span>
      </a>
    </div>
  </section>

  <!-- Audience proof -->
  <section class="cred">
    <div class="wrap">
      <div class="credrow">
        <blockquote>
          <p>&ldquo;{QUOTES[0].text}&rdquo;</p>
          <cite>{QUOTES[0].who}</cite>
        </blockquote>
        <div class="who-listens">
          <p class="wl-line">Listeners at <b>every major chipmaker</b>, the <b>leading AI labs</b>, and <b>60+ investment firms</b>, across <b>110 countries</b>.</p>
          <a class="btn btn-outline" href="/partners/">Partner with us</a>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap foot">
      <span class="mono-meta links">
        <a href={LINKS.podcast}>PODCAST</a> /
        <a href={LINKS.daily}>DAILY</a> /
        <a href={LINKS.youtube} rel="noopener">YOUTUBE</a> /
        <a href={LINKS.x} rel="noopener">X</a> /
        <a href="/partners/">PARTNERS</a>
      </span>
      <span class="mono-meta">© {year} SEMI DOPED LLC</span>
    </div>
  </footer>
</Base>

<style>
  /* Hero */
  .hero {
    background: var(--black);
    color: var(--on-black);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 90% at 50% 10%, rgba(233, 104, 34, 0.22), transparent 65%);
    pointer-events: none;
  }
  .hero .inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 48px;
    padding-bottom: 44px;
    gap: var(--sp-md);
  }
  .wm {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 4.6vw, 42px);
    letter-spacing: 0.12em;
    line-height: 1;
  }
  .wm .s { color: #fff; }
  .wm .d { color: var(--accent); }
  .tagline {
    font-size: clamp(15.5px, 1.9vw, 17px);
    color: var(--on-black-muted);
    line-height: 1.5;
  }
  .tagline .dot { color: var(--accent); }
  .ctas { display: flex; gap: var(--sp-md); flex-wrap: wrap; justify-content: center; }
  .hero-outline {
    color: #fff;
    border: 1.5px solid #fff;
    background: transparent;
  }
  .hero-outline:hover { color: var(--accent); border-color: var(--accent); }
  .mono-line {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--on-black-muted);
  }
  .mono-line a { color: var(--on-black); text-decoration: none; transition: color 0.2s ease; }
  .mono-line a:hover { color: var(--accent); }

  /* Property cards */
  .props { border-bottom: 1px solid var(--hairline); }
  .propgrid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-xl);
    padding-top: var(--sp-3xl);
    padding-bottom: var(--sp-3xl);
  }
  @media (max-width: 820px) { .propgrid { grid-template-columns: 1fr; } }
  .prop {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: var(--sp-xl);
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.2s ease;
  }
  .prop:hover { border-color: var(--accent); }
  .prop .kicker { font-size: 11px; }
  .prop h2 { font-size: 26px; }
  .desc { font-size: 16px; color: var(--muted); }
  .latest {
    border-top: 1px solid var(--hairline);
    padding-top: var(--sp-md);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .item-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.35;
    margin-top: 4px;
  }
  .item-title.sm { font-size: 15.5px; margin-top: 0; }
  .daily-row { display: flex; flex-direction: column; gap: 2px; }
  .go {
    margin-top: auto;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.03em;
    color: var(--accent);
  }

  /* Audience proof */
  .cred { border-bottom: 1px solid var(--hairline); }
  .cred .wrap { padding-top: var(--sp-2xl); padding-bottom: var(--sp-2xl); }
  .credrow {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--sp-xl);
    align-items: center;
  }
  @media (max-width: 820px) { .credrow { grid-template-columns: 1fr; } }
  .cred blockquote {
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: var(--sp-lg);
  }
  .cred blockquote p { font-size: 16.5px; line-height: 1.55; }
  .cred blockquote cite {
    display: block;
    margin-top: var(--sp-sm);
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .who-listens { display: flex; flex-direction: column; gap: var(--sp-lg); align-items: flex-start; }
  .wl-line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(19px, 2.4vw, 24px);
    line-height: 1.45;
    max-width: 26ch;
  }
  .wl-line b { color: var(--accent); font-weight: 600; }

  /* Hosts */
  .hosts { padding: var(--sp-2xl) 0 var(--sp-md); }
  .hosts h2 { font-size: 26px; margin-bottom: var(--sp-lg); }
  .hostgrid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-xl); }
  @media (max-width: 700px) { .hostgrid { grid-template-columns: 1fr; } }
  .host {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .setphoto { display: block; width: 100%; height: auto; }
  .hostmeta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sp-md);
    padding: var(--sp-md) var(--sp-lg);
  }
  .creds {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .affil {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14.5px;
    letter-spacing: 0.03em;
    color: var(--accent);
    text-decoration: none;
  }
  .affil:hover { color: var(--brick); }

  footer { border-top: 1px solid var(--hairline); }
  .foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-md);
    padding-top: var(--sp-lg);
    padding-bottom: var(--sp-lg);
  }
  .links a { color: var(--ink); text-decoration: none; transition: color 0.2s ease; }
  .links a:hover { color: var(--accent); }
</style>
