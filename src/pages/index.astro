---
import Shell from '../layouts/Shell.astro';
import Player from '../components/Player.astro';
import Platforms from '../components/Platforms.astro';
import EpisodeRow from '../components/EpisodeRow.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import WaferMark from '../components/WaferMark.astro';
import { getEpisodes, formatDateLong, formatDuration, epNum } from '../lib/feed';
import { getLatestDaily, formatDate } from '../lib/feeds';
import { QUOTES } from '../data/stats';
import { LINKS } from '../lib/links';

const episodes = await getEpisodes();
const daily = await getLatestDaily(3);
const [latest, ...rest] = episodes;
const recent = rest.slice(0, 4);
---
<Shell title="Semi Doped — The Semiconductor Podcast">
  <section class="motto">
    <div class="wrap motto-inner">
      <p class="motto-line">The world&rsquo;s most interesting industry <span class="dot">&middot;</span><br class="brk" /> and its most interesting people.</p>
    </div>
  </section>

  <section class="hero">
    <div class="wrap herogrid">
      <div class="hero-copy">
        <div class="kicker">
          <b>{epNum(latest.num)}</b>&ensp;·&ensp;{formatDateLong(latest.date)}&ensp;·&ensp;{formatDuration(latest.duration)}
        </div>
        <h1><a href={`/episodes/${latest.slug}/`}>{latest.title}</a></h1>
        <p class="dek">{latest.summary.length > 200 ? latest.summary.slice(0, 200).trimEnd() + '…' : latest.summary}</p>
        <Player src={latest.mp3} duration={latest.duration} />
        <Platforms />
      </div>
      {latest.videoId && (
        <div class="hero-video">
          <YouTubeEmbed videoId={latest.videoId} title={latest.title} />
        </div>
      )}
    </div>
  </section>

  <section class="eplist">
    <div class="wrap">
      <h2>Recent Episodes</h2>
      {recent.map((ep) => <EpisodeRow episode={ep} />)}
      <a class="all-link" href="/episodes/">ALL {episodes.length} EPISODES →</a>
    </div>
  </section>

  <section class="daily">
    <div class="wrap inner">
      <div class="wafer-bg"><WaferMark size={180} /></div>
      <div class="kicker daily-kicker">THE NEWSLETTER · EVERY TRADING DAY</div>
      <h2>Semi Doped Daily</h2>
      <p class="daily-dek">The daily brew of semiconductors. The news that matters and what it means. Free.</p>
      <div class="issues">
        {daily.map((post) => (
          <a class="issue" href={post.link} rel="noopener">
            <span class="mono-meta issue-date">{formatDate(post.date)}</span>
            <span class="issue-title">{post.title}</span>
            {post.dek && <span class="issue-dek">{post.dek}</span>}
          </a>
        ))}
      </div>
      <a class="btn btn-solid" href={LINKS.daily} rel="noopener">Sign up free</a>
    </div>
  </section>

  <section class="hosts" id="hosts">
    <div class="wrap">
      <div class="hostgrid">
        <div class="host">
          <img class="setphoto" src="/hosts/vik-set.jpg" alt="Vikram Sekar on the Semi Doped set" width="1200" height="650" loading="lazy" />
          <div class="hostmeta">
            <span class="creds">PhD EE</span>
            <a class="affil" href="https://www.viksnewsletter.com/" rel="noopener">Vik&rsquo;s Newsletter →</a>
          </div>
        </div>
        <div class="host">
          <img class="setphoto" src="/hosts/austin-set.jpg" alt="Austin Lyons on the Semi Doped set" width="1200" height="656" loading="lazy" />
          <div class="hostmeta">
            <span class="creds">MSEE + MBA</span>
            <a class="affil" href="https://www.chipstrat.com/" rel="noopener">Chipstrat →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cred">
    <div class="wrap credrow">
      <blockquote>
        <p>&ldquo;{QUOTES[0].text}&rdquo;</p>
        <cite>{QUOTES[0].who}</cite>
      </blockquote>
      <div class="who-listens">
        <p class="wl-line">Listeners at <b>every major chipmaker</b>, the <b>leading AI labs</b>, and <b>60+ investment firms</b>, across <b>110 countries</b>.</p>
        <a class="btn btn-outline" href="/partners/">Partner with us</a>
      </div>
    </div>
  </section>

</Shell>

<style>
  .hero {
    border-bottom: 1px solid var(--hairline);
    padding: 56px 0 48px;
  }
  .herogrid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: var(--sp-2xl);
    align-items: center;
  }
  @media (max-width: 940px) {
    .herogrid { grid-template-columns: 1fr; }
    .hero-video { order: -1; }
  }
  .hero .kicker { margin-bottom: 20px; }
  .hero h1 {
    font-size: clamp(28px, 3.4vw, 38px);
    letter-spacing: 0.005em;
    max-width: 22ch;
    margin-bottom: 18px;
  }
  .hero h1 a { color: var(--ink); text-decoration: none; transition: color 0.2s ease; }
  .hero h1 a:hover { color: var(--accent); }
  .hero .dek {
    font-size: 17px;
    color: var(--muted);
    max-width: 56ch;
    margin-bottom: 28px;
  }

  .motto { border-bottom: 1px solid var(--hairline); }
  .motto-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: var(--sp-md);
    padding-bottom: var(--sp-md);
  }
  .motto-line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    line-height: 1.35;
    letter-spacing: 0.01em;
    text-align: center;
  }
  .motto-line .dot { color: var(--accent); }
  @media (min-width: 700px) { .motto .brk { display: none; } }

  .eplist { padding: 20px 0 8px; border-bottom: 1px solid var(--hairline); }
  .eplist h2 { font-size: 28px; padding: 26px 0 18px; }
  .all-link {
    display: inline-block;
    margin: 26px 0 34px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.03em;
    color: var(--accent);
    text-decoration: none;
  }

  .hosts { padding: var(--sp-2xl) 0; border-bottom: 1px solid var(--hairline); }
  .hostgrid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-xl); }
  @media (max-width: 700px) { .hostgrid { grid-template-columns: 1fr; } }
  .host {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .setphoto { display: block; width: 100%; height: auto; }
  .hostmeta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sp-md);
    padding: var(--sp-md) var(--sp-lg);
  }
  .creds {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .affil {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14.5px;
    letter-spacing: 0.03em;
    color: var(--accent);
    text-decoration: none;
  }
  .affil:hover { color: var(--brick); }

  .cred { border-bottom: 1px solid var(--hairline); }
  .credrow {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--sp-xl);
    align-items: center;
    padding-top: var(--sp-2xl);
    padding-bottom: var(--sp-2xl);
  }
  @media (max-width: 820px) { .credrow { grid-template-columns: 1fr; } }
  .cred blockquote {
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: var(--sp-lg);
  }
  .cred blockquote p { font-size: 16.5px; line-height: 1.55; }
  .cred blockquote cite {
    display: block;
    margin-top: var(--sp-sm);
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .who-listens { display: flex; flex-direction: column; gap: var(--sp-lg); align-items: flex-start; }
  .wl-line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(19px, 2.4vw, 24px);
    line-height: 1.45;
    max-width: 26ch;
  }
  .wl-line b { color: var(--accent); font-weight: 600; }

  /* Daily: the black brand block, now with the latest issues */
  .daily {
    background: var(--black);
    color: var(--on-black);
    position: relative;
    overflow: hidden;
  }
  .daily::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glow-warm);
    pointer-events: none;
  }
  .daily .inner {
    position: relative;
    padding-top: var(--sp-3xl);
    padding-bottom: var(--sp-3xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-md);
  }
  .daily-kicker { color: var(--accent); }
  .daily h2 { color: #fff; font-size: 28px; }
  .daily-dek { color: var(--on-black-muted); max-width: 52ch; }
  .issues { display: flex; flex-direction: column; gap: 10px; margin: var(--sp-sm) 0 var(--sp-md); }
  .issue { display: flex; flex-direction: column; gap: 2px; text-decoration: none; }
  .issue-date { color: var(--on-black-muted); }
  .issue-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: #fff;
    transition: color 0.2s ease;
  }
  .issue:hover .issue-title { color: var(--accent); }
  .issue-dek {
    font-size: 14px;
    line-height: 1.5;
    color: var(--on-black-muted);
    max-width: 64ch;
    margin-top: 2px;
  }
  .wafer-bg {
    position: absolute;
    right: 6%;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }
  @media (max-width: 800px) { .wafer-bg { opacity: 0.25; } }
</style>
